# Kopiere nach windows\.env und trage echte Werte ein (nicht committen).

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# STT-Modell bei STT_PROVIDER=elevenlabs (z. B. scribe_v1)
ELEVENLABS_STT_MODEL=scribe_v1
STT_PROVIDER=whisper
WHISPER_PYTHON=python
WHISPER_MODEL=base
WHISPER_LANGUAGE=de
CODEX_COMMAND=codex.cmd
CODEX_WORKDIR=playground/
CODEX_TIMEOUT_SECONDS=900
CLAUDE_CODE_COMMAND=claude
OPENCLAW_COMMAND=openclaw
OPENCLAW_SESSION_KEY=main
OPENCLAW_TIMEOUT_SECONDS=120
OPENCLAW_GATEWAY_URL=
GATEWAY_TOKEN=
PUSH_TO_TALK_KEY=F8
# TTS: auto (ElevenLabs falls Keys da, sonst Windows-SAPI) | elevenlabs | windows
TTS_PROVIDER=auto

# Optional: semantisches RAG (Embeddings über OPENAI_API_KEY); 0 zum Abschalten
# RAG_EMBEDDINGS=1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# RAG_TOP_K=8

# Optional: Local tool host (Setup „enable local tool host“) — gleicher Wert im Header X-Carolus-Token
# LOCAL_TOOL_TOKEN=

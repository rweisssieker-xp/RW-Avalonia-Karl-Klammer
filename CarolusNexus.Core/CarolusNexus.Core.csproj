<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>CarolusNexus</RootNamespace>
    <AssemblyName>CarolusNexus.Core</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <UseWindowsForms>true</UseWindowsForms>
    <UseWPF>true</UseWPF>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <!-- Known local PdfPig package mix: root package is 0.1.9-alpha, transitive assemblies resolve to 1.7.0-custom-5. -->
    <NoWarn>$(NoWarn);NU1603;MSB3277</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.0" />
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.2.0" />
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="System.Speech" Version="9.0.0" />
    <PackageReference Include="UglyToad.PdfPig" Version="0.1.9-alpha001-patch1" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\CarolusNexus\Models\**\*.cs" Link="Models\%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Include="..\CarolusNexus\Services\**\*.cs" Link="Services\%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Include="..\CarolusNexus\AppPaths.cs" Link="AppPaths.cs" />
    <Compile Include="..\CarolusNexus\AppLifecycle.cs" Link="AppLifecycle.cs" />
    <Compile Include="..\CarolusNexus\AppBuildInfo.cs" Link="AppBuildInfo.cs" />
    <Compile Include="..\CarolusNexus\NexusContext.cs" Link="NexusContext.cs" />
    <Compile Include="..\CarolusNexus\NexusShell.cs" Link="NexusShell.cs" />
    <Compile Include="..\CarolusNexus\ResponsiveLayout.cs" Link="ResponsiveLayout.cs" />
    <Compile Include="..\CarolusNexus\CompanionHub.cs" Link="CompanionHub.cs" />
  </ItemGroup>
</Project>

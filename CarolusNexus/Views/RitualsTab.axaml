<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:CarolusNexus.Models;assembly=CarolusNexus.Core"
             x:Class="CarolusNexus.Views.RitualsTab">
  <Grid x:Name="RitualsRootGrid" ColumnDefinitions="*,*,*" MinHeight="420">
    <DockPanel x:Name="RitualsLibraryPane" Grid.Column="0" Margin="0,0,8,0">
      <TextBlock DockPanel.Dock="Top" Text="Flow library" FontWeight="SemiBold" Margin="0,0,0,6" />
      <TextBox x:Name="LibFilter" DockPanel.Dock="Top" Watermark="Search…" Margin="0,0,0,4" />
      <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,6">
        <TextBlock Text="Filters (risk · state · archive · category · source)" FontSize="11"
                   Foreground="{DynamicResource NexusMutedForegroundBrush}" />
        <WrapPanel>
          <ComboBox x:Name="FilterRisk" Width="108" Margin="0,0,6,4" />
          <ComboBox x:Name="FilterPublication" Width="118" Margin="0,0,6,4" />
          <ComboBox x:Name="FilterArchive" Width="108" Margin="0,0,6,4" />
          <TextBox x:Name="FilterCategory" Width="120" Watermark="category" Margin="0,0,6,4" />
          <TextBox x:Name="FilterSource" Width="120" Watermark="source" Margin="0,0,6,4" />
        </WrapPanel>
      </StackPanel>
      <ListBox x:Name="RitualList" MinHeight="140">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="models:AutomationRecipe">
            <TextBlock Text="{Binding ListCaption}" TextWrapping="Wrap" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </DockPanel>
    <DockPanel x:Name="RitualsBuilderPane" Grid.Column="1" Margin="0,0,8,0">
      <TextBlock DockPanel.Dock="Top" Text="Flow builder" FontWeight="SemiBold" Margin="0,0,0,4" />
      <TextBlock x:Name="QueueStatusLine" DockPanel.Dock="Top" FontSize="11"
                 Foreground="{DynamicResource NexusMutedForegroundBrush}" Margin="0,0,0,4"
                 Text="Job queue: —" TextWrapping="Wrap" />
      <TextBox x:Name="JobQueueDetail" DockPanel.Dock="Top" IsReadOnly="True" AcceptsReturn="True"
               MinHeight="100" MaxHeight="200" FontSize="11" FontFamily="Consolas,Courier New,monospace"
               TextWrapping="Wrap" Margin="0,0,0,8"
               Watermark="ritual-job-queue.json — pending + history" />
      <ScrollViewer>
        <StackPanel Spacing="6">
          <TextBox x:Name="RitualName" Watermark="Name" />
          <TextBox x:Name="RitualCategory" Watermark="Category (filter / SOP bucket)" />
          <TextBox x:Name="RitualDesc" Watermark="Description" AcceptsReturn="True" MinHeight="48" />
          <TextBlock Text="Governance (handbook §16.5)" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="Approval" />
            <ComboBox x:Name="ApprovalModeBox" Grid.Row="0" Grid.Column="1" />
            <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Risk" />
            <ComboBox x:Name="RiskLevelBox" Grid.Row="1" Grid.Column="1" />
            <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="Adapter" />
            <TextBox x:Name="AdapterAffinityBox" Grid.Row="2" Grid.Column="1" Watermark="e.g. explorer, ax2012" />
            <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="Confidence" />
            <TextBox x:Name="ConfidenceSourceBox" Grid.Row="3" Grid.Column="1" Watermark="Teach, LLM, SOP …" />
            <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="Max autonomy" />
            <TextBox x:Name="MaxAutonomyStepsBox" Grid.Row="4" Grid.Column="1" Watermark="0 = unlimited (hint)" />
          </Grid>
          <WrapPanel>
            <Button x:Name="BtnAiSuggestName" Content="AI: short title" Margin="0,0,6,6"
                    ToolTip.Tip="Suggests a short flow name via LLM (description and/or steps)." />
            <Button x:Name="BtnSaveRitual" Content="save flow" Margin="0,0,6,6" />
            <Button x:Name="BtnDeleteRitual" Content="delete" Margin="0,0,6,6" />
            <Button x:Name="BtnClone" Content="clone" Margin="0,0,6,6" />
            <Button x:Name="BtnArchive" Content="archive" Margin="0,0,6,6" />
            <Button x:Name="BtnPublish" Content="publish flow" Margin="0,0,6,6" />
            <Button x:Name="BtnQueue" Content="queue for run" Margin="0,0,6,6" />
            <Button x:Name="BtnApproveJob" Content="approve next job" Margin="0,0,6,6" />
            <Button x:Name="BtnDryRun" Content="dry run" Margin="0,0,6,6" />
            <Button x:Name="BtnRunRitual" Content="run flow" Margin="0,0,6,6" />
            <Button x:Name="BtnRunNextStep" Content="run next step" Margin="0,0,6,6" />
            <Button x:Name="BtnResume" Content="resume flow" Margin="0,0,6,6" />
            <Button x:Name="BtnFlowTest" Content="test report" Margin="0,0,6,6" />
            <Button x:Name="BtnAuditExport" Content="audit export" Margin="0,0,6,6" />
          </WrapPanel>
          <TextBlock Text="Teach" FontWeight="SemiBold" />
          <WrapPanel>
            <Button x:Name="BtnInstallTemplates" Content="install templates" Margin="0,0,6,6" />
            <Button x:Name="BtnPromoteHist" Content="promote from history" Margin="0,0,6,6" />
            <Button x:Name="BtnPromoteWatch" Content="promote from watch" Margin="0,0,6,6" />
            <Button x:Name="BtnTeachStart" Content="start teach" Margin="0,0,6,6" />
            <Button x:Name="BtnTeachCapture" Content="capture foreground step" Margin="0,0,6,6" />
            <Button x:Name="BtnTeachStop" Content="stop teach" Margin="0,0,6,6" />
          </WrapPanel>
        </StackPanel>
      </ScrollViewer>
    </DockPanel>
    <DockPanel x:Name="RitualsStepsPane" Grid.Column="2">
      <TextBlock DockPanel.Dock="Top" Text="Structured Steps (JSON)" FontWeight="SemiBold" Margin="0,0,0,6" />
      <TextBox x:Name="StepsEditor" AcceptsReturn="True" FontFamily="Consolas,Courier New,monospace"
               Watermark="JSON / steps — persisted in automation-recipes.json" />
    </DockPanel>
  </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CarolusNexus.Views.ExperimentsTab">
  <ScrollViewer>
    <StackPanel Spacing="12" Margin="8">
      <TextBlock Text="Experiments (Tier C)" FontWeight="SemiBold" FontSize="16" />
      <TextBlock TextWrapping="Wrap"
                 Text="Optional research and unstable toggles — same scope as the WinUI shell. Not part of the default product promise." />
      <Border Padding="12" CornerRadius="6" BorderBrush="{DynamicResource NexusTileBorderBrush}"
              BorderThickness="1" Background="{DynamicResource NexusTileBackgroundBrush}">
        <StackPanel Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Tag" />
          <TextBlock x:Name="TagLine" FontFamily="Consolas,Courier New,monospace" />
        </StackPanel>
      </Border>
      <TextBlock TextWrapping="Wrap" FontSize="11"
                 Foreground="{DynamicResource NexusMutedForegroundBrush}"
                 Text="Use the main Setup tab for provider and safety. Tier C hooks may read optional keys from windows/.env when documented." />
      <Border Padding="12" CornerRadius="6" BorderBrush="{DynamicResource NexusTileBorderBrush}"
              BorderThickness="1" Background="{DynamicResource NexusTileBackgroundBrush}">
        <StackPanel Spacing="8">
          <TextBlock FontWeight="SemiBold" Text="Computer-use → SimplePlanSimulator (audit)" />
          <TextBlock TextWrapping="Wrap" FontSize="11"
                     Foreground="{DynamicResource NexusMutedForegroundBrush}"
                     Text="Dry-run is always safe. Real Win32 only with Safety profile “power-user” and allowed tokens (Handbuch §23.0)." />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="BtnCuDryRun" Content="Run sample (dry-run)" Padding="10,6" />
            <Button x:Name="BtnCuExecute" Content="Run sample (execute)" Padding="10,6"
                    ToolTip.Tip="Uses current settings; real steps only if power-user + PlanGuard allows." />
          </StackPanel>
          <TextBox x:Name="CuLogOut" IsReadOnly="True" AcceptsReturn="True" MinHeight="120"
                   TextWrapping="Wrap" FontFamily="Consolas,Courier New,monospace" FontSize="11" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CarolusNexus.Views.SetupTab">
  <ScrollViewer>
    <StackPanel Spacing="10" HorizontalAlignment="Stretch">
      <TextBlock Text="Setup · provider, mode, safety (§5.4)" FontWeight="SemiBold" FontSize="14" />
      <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
        <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="Provider" />
        <ComboBox x:Name="ProviderBox" Grid.Row="0" Grid.Column="1" />
        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Mode" />
        <ComboBox x:Name="ModeBox" Grid.Row="1" Grid.Column="1" />
        <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="Model" />
        <TextBox x:Name="ModelBox" Grid.Row="2" Grid.Column="1" />
        <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="UI theme" />
        <ComboBox x:Name="UiThemeBox" Grid.Row="3" Grid.Column="1"
                  ToolTip.Tip="Dark / Light / System (Default) — applied after „save settings“." />
        <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="Toggles" FontWeight="SemiBold" Margin="0,8,0,0" />
        <CheckBox x:Name="SpeakResponses" Grid.Row="5" Grid.ColumnSpan="2" Content="speak responses" />
        <CheckBox x:Name="UseLocalKnowledge" Grid.Row="6" Grid.ColumnSpan="2" Content="use local knowledge" />
        <CheckBox x:Name="SuggestAutomations" Grid.Row="7" Grid.ColumnSpan="2" Content="suggest automations" />
        <CheckBox x:Name="EnableCliRoutes" Grid.Row="8" Grid.ColumnSpan="2"
                  Content="Enable CLI ask routes (use codex / use claude code / use openclaw)" />
        <CheckBox x:Name="EnableMissionRoutes" Grid.Row="9" Grid.ColumnSpan="2"
                  Content="Enable mission/autonomy routes (autonomy, predictive, orbit)" />
        <CheckBox x:Name="EnableRadicalAuto" Grid.Row="10" Grid.ColumnSpan="2"
                  Content="Enable radical auto routes (radical-auto + radical run)" />
        <CheckBox x:Name="EnableRadicalIdeas" Grid.Row="11" Grid.ColumnSpan="2"
                  Content="Enable radical idea blueprint routes (radical ...)" />
        <CheckBox x:Name="MissionFallbackMode" Grid.Row="12" Grid.ColumnSpan="2"
                  Content="Fallback mission mode for plain ask prompts" />
        <CheckBox x:Name="IncludeUiaInAsk" Grid.Row="13" Grid.ColumnSpan="2"
                  Content="Ask: attach UIA snapshot of foreground window (Windows)" />
        <CheckBox x:Name="ConversationMemory" Grid.Row="14" Grid.ColumnSpan="2"
                  Content="Conversation memory (opt-in, file-backed, token-trimmed)" />
        <TextBlock Grid.Row="15" VerticalAlignment="Center" Text="Memory max chars" />
        <TextBox x:Name="MemoryMaxCharsBox" Grid.Row="15" Grid.Column="1" Watermark="2000–32000, default 8000" />
        <CheckBox x:Name="HighRiskSecondConfirm" Grid.Row="16" Grid.ColumnSpan="2"
                  Content="High-risk plans: require second confirmation before run" />
        <TextBlock Grid.Row="17" Grid.ColumnSpan="2" Text="Safety Center" FontWeight="SemiBold" Margin="0,8,0,0" />
        <TextBlock Grid.Row="18" VerticalAlignment="Center" Text="Profile" />
        <ComboBox x:Name="SafetyProfile" Grid.Row="18" Grid.Column="1" />
      </Grid>
      <CheckBox x:Name="UseVerticalTabs"
                Content="Vertical tab strip (left side, saves with „save settings“)"
                ToolTip.Tip="More room for tab labels; Ctrl+P still jumps quickly." />
      <CheckBox x:Name="NeverAutoSend" Content="never auto-send" />
      <CheckBox x:Name="NeverAutoPost" Content="never auto-post / book" />
      <CheckBox x:Name="PanicStop" Content="panic stop enabled" />
      <TextBlock Text="Denylist (comma-separated)" />
      <TextBox x:Name="DenylistBox" />
      <Expander Header="Watch &amp; local tool host" IsExpanded="True" Margin="0,4,0,0">
        <StackPanel Spacing="10">
      <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
        <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="Watch interval (s)" />
        <TextBox x:Name="WatchIntervalBox" Grid.Row="0" Grid.Column="1" Watermark="15–600, default 45" />
        <CheckBox x:Name="ProactiveLlm" Grid.Row="1" Grid.ColumnSpan="2"
                  Content="Proactive LLM hint (Dashboard, watch mode only)" />
        <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="LLM min interval (s)" />
        <TextBox x:Name="ProactiveIntervalBox" Grid.Row="2" Grid.Column="1" Watermark="60–3600, default 180" />
        <CheckBox x:Name="EnableToolHost" Grid.Row="3" Grid.ColumnSpan="2"
                  Content="Start local tool host (127.0.0.1, see LOCAL_TOOL_TOKEN)" />
        <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="Tool host port" />
        <TextBox x:Name="ToolHostPortBox" Grid.Row="4" Grid.Column="1" Watermark="17888" />
      </Grid>
        </StackPanel>
      </Expander>
      <Expander Header="Dynamics AX 2012 (optional, test tenant)" IsExpanded="False" Margin="0,4,0,0">
        <StackPanel Spacing="10">
      <TextBlock Text="AIF / OData / COM" FontWeight="SemiBold" Margin="0,0,0,4" />
      <CheckBox x:Name="AxIntegrationEnabled" Content="Enable ax.* integration tokens" />
      <TextBlock Text="AX test tenant label (optional, non-secret)" />
      <TextBox x:Name="AxTenantLabel" Watermark="e.g. CONTOSO-DEV" />
      <TextBlock VerticalAlignment="Center" Text="Integration backend" />
      <ComboBox x:Name="AxBackendBox" />
      <TextBlock Text="OData base URL" />
      <TextBox x:Name="AxODataBaseUrlBox" Watermark="https://AOS/AX/Data/" />
      <CheckBox x:Name="AxODataUseWinCred" Content="OData / AIF HTTP: use Windows default credentials" />
      <TextBlock Text="AIF service base URL (optional ping)" />
      <TextBox x:Name="AxAifBaseUrlBox" Watermark="https://AOS:8148/MicrosoftDynamicsAXAif50/…" />
      <TextBlock Text="DataAreaId / company (test)" />
      <TextBox x:Name="AxDataAreaBox" Watermark="USMF, DAT, …" />
      <TextBlock Text="BusinessConnectorNet.dll path (COM)" />
      <TextBox x:Name="AxBcDllBox"
               Watermark="Path to Microsoft.Dynamics.BusinessConnectorNet.dll" />
      <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto">
        <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="COM: AOS" />
        <TextBox x:Name="AxBcAosBox" Grid.Row="0" Grid.Column="1" Watermark="host:port" />
        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="COM: database" />
        <TextBox x:Name="AxBcDbBox" Grid.Row="1" Grid.Column="1" />
        <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="COM: language" />
        <TextBox x:Name="AxBcLangBox" Grid.Row="2" Grid.Column="1" Watermark="en-us" />
      </Grid>
        </StackPanel>
      </Expander>
      <Expander Header=".env overview (keys only)" IsExpanded="False" Margin="0,4,0,0">
        <StackPanel Spacing="8">
      <TextBox x:Name="EnvSummary" IsReadOnly="True" AcceptsReturn="True" MinHeight="100" FontFamily="Consolas,Courier New,monospace" />
      <TextBlock x:Name="EnvPathHint" FontSize="11" Foreground="{DynamicResource NexusMutedForegroundBrush}"
                 TextWrapping="Wrap" />
        </StackPanel>
      </Expander>
    </StackPanel>
  </ScrollViewer>
</UserControl>

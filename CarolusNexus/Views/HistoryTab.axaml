<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CarolusNexus.Views.HistoryTab">
  <Grid x:Name="HistRootGrid" ColumnDefinitions="280,*" MinHeight="400">
    <DockPanel x:Name="HistLeftPane" Grid.Column="0" Margin="0,0,12,0">
      <TextBox x:Name="HistFilter" DockPanel.Dock="Top" Watermark="Search…" Margin="0,0,0,6" />
      <Button x:Name="BtnSelfHealHint" DockPanel.Dock="Bottom" Content="self-heal hint (last audit failure)" Margin="0,8,0,0" />
      <Button x:Name="BtnCreateRitual" DockPanel.Dock="Bottom" Content="create ritual from selection" Margin="0,8,0,0" />
      <ListBox x:Name="HistList" />
    </DockPanel>
    <DockPanel x:Name="HistRightPane" Grid.Column="1">
      <TextBlock DockPanel.Dock="Top" Text="Detail" FontWeight="SemiBold" Margin="0,0,0,6" />
      <TextBox x:Name="HistDetail" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" />
    </DockPanel>
  </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CarolusNexus.Views.ConsoleTab">
  <DockPanel MinHeight="400">
    <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,8">
      <Grid ColumnDefinitions="Auto,*" MaxWidth="900">
        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Agent" Margin="0,0,12,0" />
        <ComboBox x:Name="AgentBox" Grid.Column="1" MinWidth="140" HorizontalAlignment="Stretch" />
      </Grid>
      <TextBox x:Name="AgentPrompt" AcceptsReturn="True" MinHeight="64" Watermark="Prompt for Codex / Claude Code / OpenClaw" />
      <Button x:Name="BtnRunAgent" Content="run selected agent" HorizontalAlignment="Left" Padding="12,8" />
      <TextBlock x:Name="OutputPathHint" FontSize="11"
                 Foreground="{DynamicResource NexusMutedForegroundBrush}" />
    </StackPanel>
    <TextBox x:Name="AgentOutput" AcceptsReturn="True" IsReadOnly="True" FontFamily="Consolas,Courier New,monospace" />
  </DockPanel>
</UserControl>

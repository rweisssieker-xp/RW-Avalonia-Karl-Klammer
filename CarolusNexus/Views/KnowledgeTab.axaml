<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CarolusNexus.Views.KnowledgeTab">
  <Grid x:Name="KnowRootGrid" ColumnDefinitions="240,*" MinHeight="400">
    <DockPanel x:Name="KnowLeftPane" Grid.Column="0" Margin="0,0,12,0">
      <StackPanel DockPanel.Dock="Bottom" Spacing="6" Margin="0,8,0,0">
        <TextBox x:Name="SearchQuery" Watermark="Search file name…" />
        <Button x:Name="BtnSearch" Content="search" HorizontalAlignment="Stretch" />
        <Button x:Name="BtnImport" Content="import files" HorizontalAlignment="Stretch" />
        <Button x:Name="BtnRemove" Content="remove doc" HorizontalAlignment="Stretch" />
        <Button x:Name="BtnReindex" Content="reindex" HorizontalAlignment="Stretch" />
        <Button x:Name="BtnSuggestRitual" Content="suggest ritual from doc" HorizontalAlignment="Stretch" />
      </StackPanel>
      <TextBlock DockPanel.Dock="Top" Text="Documents" FontWeight="SemiBold" Margin="0,0,0,6" />
      <ListBox x:Name="DocList" />
    </DockPanel>
    <DockPanel x:Name="KnowRightPane" Grid.Column="1">
      <TextBlock DockPanel.Dock="Top" Text="Document Preview" FontWeight="SemiBold" Margin="0,0,0,6" />
      <TextBox x:Name="Preview" AcceptsReturn="True" IsReadOnly="True" TextWrapping="Wrap" />
    </DockPanel>
  </Grid>
</UserControl>

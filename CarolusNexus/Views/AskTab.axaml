<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CarolusNexus.Views.AskTab">
  <Grid x:Name="AskRootGrid" RowDefinitions="Auto,Auto,*">
    <StackPanel x:Name="AskToolbarHost" Grid.Row="0" Spacing="8" Margin="0,0,0,8">
      <TextBox x:Name="PromptBox" AcceptsReturn="True" MinHeight="72"
               Watermark="Question / vision / RAG — Enter sends · Shift+Enter new line · global PTT: hold F8 (see .env PUSH_TO_TALK_KEY) — CLI: use codex … / use codex with screen …" />
      <StackPanel Orientation="Horizontal" Spacing="12">
        <CheckBox x:Name="IncludeScreenshots" Content="Include screenshots" IsChecked="True" />
        <CheckBox x:Name="UseKnowledgeInAsk" Content="Use local knowledge in Ask" IsChecked="True"
                  ToolTip.Tip="UIA context is controlled in Setup (Ask: UIA snapshot)." />
        <CheckBox x:Name="MissionMode" Content="Autonomy mode" IsChecked="True" />
        <CheckBox x:Name="MissionAutoApproveHighRisk" Content="Auto-approve high risk" IsChecked="False"
                  ToolTip.Tip="Only use if policy accepts automated high-risk execution." />
      </StackPanel>
      <TextBlock x:Name="MissionRibbonStatus" Text="Mission status: idle" FontSize="11"
                 Foreground="{DynamicResource NexusMutedForegroundBrush}" />
      <WrapPanel Orientation="Horizontal">
        <Button x:Name="BtnAskNow" Classes="nexus-primary" Content="Ask now" Margin="0,0,6,6" Padding="12,7" />
        <Button x:Name="BtnApproveRun" Classes="nexus-primary" Content="Approve + run" Margin="0,0,6,6" Padding="12,7"
                ToolTip.Tip="Confirmation dialog — explicit gate before execution." />
        <Button x:Name="BtnMissionRun" Classes="nexus-primary" Content="Autonomy run" Margin="0,0,6,6" Padding="10,6" />
        <Button x:Name="BtnMissionPredictive" Classes="nexus-primary" Content="Predictive next action" Margin="0,0,6,6" Padding="10,6"
                ToolTip.Tip="Creates predictive mission suggestion, dry-run only." />
        <Button x:Name="BtnRunPlan" Content="Run plan" Margin="0,0,6,6" Padding="10,6"
                ToolTip.Tip="Runs the detected plan without an extra confirmation dialog." />
        <Button x:Name="BtnMissionPause" Content="Pause mission" Margin="0,0,6,6" Padding="10,6" />
        <Button x:Name="BtnMissionAbort" Classes="nexus-danger" Content="Abort mission" Margin="0,0,6,6" Padding="10,6" />
        <Button x:Name="BtnPanic" Classes="nexus-danger" Content="Panic stop" Margin="0,0,6,6" Padding="10,6" />
      </WrapPanel>
      <Expander Header="More: voice, tests, plan steps, copy…" IsExpanded="False">
        <StackPanel Spacing="8">
          <WrapPanel Orientation="Horizontal">
            <Button x:Name="BtnSmoke" Content="Smoke test" Margin="0,0,6,6" Padding="10,6" />
            <Button x:Name="BtnImportAudio" Content="Import audio + transcribe" Margin="0,0,6,6" Padding="10,6" />
            <Button x:Name="BtnPttStart" Content="Start push-to-talk" Margin="0,0,6,6" Padding="10,6" />
            <Button x:Name="BtnPttStop" Content="Stop + ask" Margin="0,0,6,6" Padding="10,6" />
            <Button x:Name="BtnCancelRec" Content="Cancel recording" Margin="0,0,6,6" Padding="10,6" />
            <Button x:Name="BtnClearConv" Content="Clear conversation" Margin="0,0,6,6" Padding="10,6" />
            <Button x:Name="BtnRunNext" Content="Run next step" Margin="0,0,6,6" Padding="10,6" />
            <Button x:Name="BtnSaveRitual" Content="Save plan as flow" Margin="0,0,6,6" Padding="10,6" />
            <Button x:Name="BtnClearPlan" Content="Clear plan" Margin="0,0,6,6" Padding="10,6" />
            <Button x:Name="BtnSpeak" Content="Speak response" Margin="0,0,6,6" Padding="10,6" />
            <Button x:Name="BtnCopyAnswer" Content="Copy answer" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Copies the assistant reply to the clipboard." />
          </WrapPanel>
          <TextBlock Text="AI helpers" FontWeight="SemiBold" FontSize="11" />
          <WrapPanel Orientation="Horizontal">
            <Button x:Name="BtnInsertKnowledge" Content="Insert knowledge" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Appends a snippet from knowledge\ to the prompt (ranked by current text)." />
            <Button x:Name="BtnPolishPrompt" Content="Polish prompt" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Tightens the prompt via LLM (no new facts)." />
            <Button x:Name="BtnPolishAnswer" Content="Polish answer" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Rewrites the last assistant reply: clearer, same facts." />
            <Button x:Name="BtnParseJsonPlan" Content="JSON plan from reply" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Reads JSON fences or a steps array in the assistant reply." />
            <Button x:Name="BtnLlmJsonPlan" Content="AI: structured steps" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Second LLM call: extract steps as JSON." />
            <Button x:Name="BtnExplainPlan" Content="Explain plan / risk" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Short LLM explanation of current plan steps (dry-run companion text)." />
            <Button x:Name="BtnAiPromptPack" Content="AI USP prompt pack" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Builds a demo-ready prompt pack from provider/RAG/live context readiness." />
            <Button x:Name="BtnAiOpportunityFlow" Content="AI opportunity flow" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Creates a governed draft flow from the current AI task and foreground context." />
            <Button x:Name="BtnAiUspBrief" Content="Export AI USP brief" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Exports a markdown proof brief for demos and pilots." />
            <Button x:Name="BtnAiRagGap" Content="AI/RAG gap report" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Shows which provider/RAG/live-context signals are missing for a strong AI demo." />
            <Button x:Name="BtnAiExecutiveOnePager" Content="Executive AI one-pager" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Exports a pilot/sales-ready one-pager." />
            <Button x:Name="BtnAiDemoFlow" Content="AI demo flow" Margin="0,0,6,6" Padding="10,6"
                    ToolTip.Tip="Creates a low-risk demo flow with RAG proof, executive one-pager and checkpoint." />
          </WrapPanel>
          <TextBlock Text="Quick prompts" FontSize="11" Foreground="{DynamicResource NexusMutedForegroundBrush}" />
          <WrapPanel Orientation="Horizontal">
            <Button x:Name="BtnChipSummary" Content="+ Summary" Margin="0,0,6,6" Padding="8,5" FontSize="11" />
            <Button x:Name="BtnChipNext" Content="+ Next steps" Margin="0,0,6,6" Padding="8,5" FontSize="11" />
            <Button x:Name="BtnChipRisks" Content="+ Risks" Margin="0,0,6,6" Padding="8,5" FontSize="11" />
            <Button x:Name="BtnChipExplain" Content="+ Explain …" Margin="0,0,6,6" Padding="8,5" FontSize="11" />
          </WrapPanel>
        </StackPanel>
      </Expander>
      <Border Padding="8" CornerRadius="4" Background="{DynamicResource NexusCardBackgroundBrush}"
              BorderBrush="{DynamicResource NexusCardBorderBrush}" BorderThickness="1">
        <TextBlock Text="ax.* tokens: real Win32 only with Safety profile “power-user” + PlanGuard. CLI agents: use codex / claude / openclaw phrases in the prompt."
                   FontSize="11" Foreground="{DynamicResource NexusMutedForegroundBrush}" TextWrapping="Wrap" />
      </Border>
    </StackPanel>
    <ProgressBar x:Name="AskBusyBar" Grid.Row="1" Height="4" Margin="0,0,0,8"
                 IsIndeterminate="True" IsVisible="False" />
    <Grid x:Name="AskPaneGrid" Grid.Row="2" ColumnDefinitions="*,6,*">
      <ScrollViewer x:Name="AskLeftScroll" Grid.Column="0" Margin="0,0,4,0">
        <StackPanel Spacing="8">
          <TextBlock Text="Assistant Response" FontWeight="SemiBold" />
          <TextBox x:Name="AssistantOut" IsReadOnly="True" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
          <TextBlock Text="Retrieval + Context" FontWeight="SemiBold" />
          <TextBox x:Name="RetrievalOut" IsReadOnly="True" AcceptsReturn="True" MinHeight="80" TextWrapping="Wrap" />
          <TextBlock x:Name="RetrievalSourcesHeader" Text="RAG sources" FontWeight="SemiBold" FontSize="11"
                     IsVisible="False" />
          <StackPanel x:Name="RetrievalSourcesPanel" Spacing="4" IsVisible="False" />
          <TextBlock Text="Safety / Recovery" FontWeight="SemiBold" />
          <TextBox x:Name="SafetyOut" IsReadOnly="True" AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap" />
          <TextBlock Text="Transcript / Audio" FontWeight="SemiBold" />
          <TextBox x:Name="TranscriptOut" IsReadOnly="True" AcceptsReturn="True" MinHeight="50" TextWrapping="Wrap" />
        </StackPanel>
      </ScrollViewer>
      <GridSplitter x:Name="AskPaneSplitter" Grid.Column="1" Width="6"
                    Background="{DynamicResource NexusHeaderBorderBrush}" />
      <ScrollViewer x:Name="AskRightScroll" Grid.Column="2" Margin="4,0,0,0">
        <StackPanel Spacing="8">
          <TextBlock Text="Action Plan Preview" FontWeight="SemiBold" />
          <TextBox x:Name="PlanPreview" IsReadOnly="True" AcceptsReturn="True" MinHeight="100" TextWrapping="Wrap" />
          <TextBlock Text="Action Plan Execution" FontWeight="SemiBold" />
          <TextBox x:Name="PlanExec" IsReadOnly="True" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" FontFamily="Consolas,Courier New,monospace" />
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>

<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CarolusNexus.App"
             RequestedThemeVariant="Default">
  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon ToolTipText="Carolus Nexus">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Carolus Nexus öffnen" Click="OnTrayOpen" />
            <NativeMenuItem Header="Beenden" Click="OnTrayQuit" />
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>
</Application>

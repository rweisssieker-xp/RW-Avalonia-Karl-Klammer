<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CarolusNexus"
        x:Class="CarolusNexus.MainWindow"
        Title="Karl Klammer"
        Width="400"
        Height="560"
        MinWidth="320"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="True"
        Topmost="False">
  <Border Margin="16"
          CornerRadius="16"
          Background="#F5F5F0"
          BorderBrush="#C8C8C0"
          BorderThickness="1"
          BoxShadow="0 8 24 0 #40000000">
    <Grid RowDefinitions="Auto,*">
      <Grid Grid.Row="0"
            Margin="12,10,8,4"
            ColumnDefinitions="*,Auto,Auto">
        <TextBlock Text="Karl Klammer"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Foreground="#666"
                   IsHitTestVisible="False" />
        <CheckBox x:Name="CompanionToggle"
                  Grid.Column="1"
                  Margin="8,0,8,0"
                  VerticalAlignment="Center"
                  Content="Begleiter am Cursor"
                  FontSize="11"
                  IsChecked="True"
                  ToolTip.Tip="Zeigt Karl neben der Maus (Windows, klick-durchlässig)." />
        <Button Grid.Column="2"
                Padding="8,2"
                Content="&#215;"
                FontSize="12"
                ToolTip.Tip="Schließen"
                Click="OnCloseClick" />
      </Grid>

      <ScrollViewer Grid.Row="1"
                    Margin="12,0,12,12"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10">
          <Border Padding="0"
                  Background="Transparent"
                  PointerPressed="OnDragPointerPressed">
            <StackPanel Spacing="0">
              <Border Padding="14,12"
                      CornerRadius="14"
                      Background="#FFFACD"
                      BorderBrush="#C4B896"
                      BorderThickness="1">
                <TextBlock x:Name="HintText"
                           FontSize="14"
                           Foreground="#2a2a2a"
                           TextWrapping="Wrap"
                           LineHeight="20" />
              </Border>
              <Path Margin="0,-1,0,0"
                    HorizontalAlignment="Center"
                    Data="M 0,0 L 22,0 L 11,12 Z"
                    Fill="#FFFACD"
                    Stroke="#C4B896"
                    StrokeThickness="1"
                    Stretch="None" />
            </StackPanel>
          </Border>

          <Border x:Name="SceneBob"
                  Height="300"
                  CornerRadius="12"
                  ClipToBounds="True"
                  Background="#1a1c20"
                  BorderBrush="#3d4450"
                  BorderThickness="1"
                  PointerPressed="OnDragPointerPressed">
            <Border.RenderTransform>
              <TranslateTransform />
            </Border.RenderTransform>
            <local:OfficeScene3D HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch" />
          </Border>

          <TextBlock Text="OpenGL-3D: Papier, „Klammer“ und kleiner Akzent — alles mit Licht und Rotation."
                     FontSize="11"
                     Foreground="#777"
                     TextWrapping="Wrap"
                     LineHeight="16" />

          <Button HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="12,8"
                  Content="Noch ein Tipp…"
                  Click="OnNextTipClick" />
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</Window>

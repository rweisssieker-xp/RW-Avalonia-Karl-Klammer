<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CarolusNexus.Views"
        x:Class="CarolusNexus.MainWindow"
        Title="Carolus Nexus"
        Width="1180"
        Height="840"
        MinWidth="900"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
  <DockPanel>
    <Border DockPanel.Dock="Top" Background="{DynamicResource NexusHeaderBackgroundBrush}"
            BorderBrush="{DynamicResource NexusHeaderBorderBrush}" BorderThickness="0,0,0,1" Padding="14,10">
      <StackPanel Spacing="10">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
          <StackPanel Spacing="2">
            <TextBlock Text="Carolus Nexus" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="Windows-Operator-Desktop · Persona: Karl Klammer" FontSize="12"
                       Foreground="{DynamicResource NexusMutedForegroundBrush}" />
            <TextBlock x:Name="StatusLine" Text="Bereit" FontSize="12" />
          </StackPanel>
          <CheckBox x:Name="CompanionToggle"
 Grid.Column="1"
                    Margin="12,0,12,0"
                    VerticalAlignment="Center"
                    Content="Begleiter am Cursor"
                    FontSize="11"
                    IsChecked="True"
                    ToolTip.Tip="Karl neben der Maus (Windows, klick-durchlässig)." />
          <Button Grid.Column="2"
                  Padding="10,4"
                  Margin="0,0,8,0"
                  Content="Handbuch"
                  Click="OnOpenHandbookClick"
                  ToolTip.Tip="Öffnet docs/Carolus-Nexus-Benutzerhandbuch.md (Repository-Wurzel)." />
          <Button Grid.Column="3"
                  Padding="10,4"
                  Content="Schließen"
                  Click="OnCloseClick" />
        </Grid>
        <WrapPanel>
          <Border Margin="0,0,8,6" Padding="8,4" CornerRadius="4"
                  Background="{DynamicResource NexusBadgeBackgroundBrush}">
            <TextBlock x:Name="BadgeLayout" Text="Layout: Shell" FontSize="11" />
          </Border>
          <Border Margin="0,0,8,6" Padding="8,4" CornerRadius="4"
                  Background="{DynamicResource NexusBadgeBackgroundBrush}">
            <TextBlock x:Name="BadgeEnv" Text="Environment: —" FontSize="11" />
          </Border>
          <Border Margin="0,0,8,6" Padding="8,4" CornerRadius="4"
                  Background="{DynamicResource NexusBadgeBackgroundBrush}">
            <TextBlock x:Name="BadgeSpeech" Text="Speech: —" FontSize="11" />
          </Border>
          <Border Margin="0,0,8,6" Padding="8,4" CornerRadius="4"
                  Background="{DynamicResource NexusBadgeBackgroundBrush}">
            <TextBlock x:Name="BadgeAuto" Text="Automation: —" FontSize="11" />
          </Border>
          <Border Margin="0,0,8,6" Padding="8,4" CornerRadius="4"
                  Background="{DynamicResource NexusBadgeBackgroundBrush}">
            <TextBlock x:Name="BadgeKnow" Text="Knowledge: lokal" FontSize="11" />
          </Border>
        </WrapPanel>
        <Grid ColumnDefinitions="*,*,*">
          <Border Padding="8" CornerRadius="6" BorderBrush="{DynamicResource NexusTileBorderBrush}"
                  BorderThickness="1" Background="{DynamicResource NexusTileBackgroundBrush}">
            <StackPanel>
              <TextBlock Text="Operator Memory" FontWeight="SemiBold" FontSize="11" />
              <TextBlock x:Name="TileMemory" TextWrapping="Wrap" FontSize="11" Text="—" />
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Padding="8" CornerRadius="6" BorderBrush="{DynamicResource NexusTileBorderBrush}"
                  BorderThickness="1" Background="{DynamicResource NexusTileBackgroundBrush}">
            <StackPanel>
              <TextBlock Text="Live Context" FontWeight="SemiBold" FontSize="11" />
              <TextBlock x:Name="TileLive" TextWrapping="Wrap" FontSize="11" Text="—" />
            </StackPanel>
          </Border>
          <Border Grid.Column="2" Padding="8" CornerRadius="6" BorderBrush="{DynamicResource NexusTileBorderBrush}"
                  BorderThickness="1" Background="{DynamicResource NexusTileBackgroundBrush}">
            <StackPanel>
              <TextBlock Text="Environment" FontWeight="SemiBold" FontSize="11" />
              <TextBlock x:Name="TileEnv" TextWrapping="Wrap" FontSize="11" Text="—" />
            </StackPanel>
          </Border>
        </Grid>
        <WrapPanel>
          <Button x:Name="BtnRefreshAll" Content="refresh all" Margin="0,0,8,6" Padding="12,6" />
          <Button x:Name="BtnSaveSettings" Content="save settings" Margin="0,0,8,6" Padding="12,6" />
          <Button x:Name="BtnReindex" Content="reindex knowledge" Margin="0,0,8,6" Padding="12,6" />
          <Button x:Name="BtnRefreshApp" Content="refresh active app" Margin="0,0,8,6" Padding="12,6" />
          <Button x:Name="BtnExportDiag" Content="export diagnostics" Margin="0,0,8,6" Padding="12,6" />
        </WrapPanel>
      </StackPanel>
    </Border>
    <TabControl x:Name="MainTabs" Margin="10,8,10,10">
      <TabItem Header="Ask">
        <views:AskTab x:Name="TabAsk" Margin="8" />
      </TabItem>
      <TabItem Header="Dashboard">
        <views:DashboardTab x:Name="TabDashboard" Margin="8" />
      </TabItem>
      <TabItem Header="Setup">
        <views:SetupTab x:Name="TabSetup" Margin="8" />
      </TabItem>
      <TabItem Header="Knowledge">
        <views:KnowledgeTab x:Name="TabKnowledge" Margin="8" />
      </TabItem>
      <TabItem Header="Rituals">
        <views:RitualsTab x:Name="TabRituals" Margin="8" />
      </TabItem>
      <TabItem Header="History">
        <views:HistoryTab x:Name="TabHistory" Margin="8" />
      </TabItem>
      <TabItem Header="Diagnostics">
        <views:DiagnosticsTab x:Name="TabDiagnostics" Margin="8" />
      </TabItem>
      <TabItem Header="Console">
        <views:ConsoleTab x:Name="TabConsole" Margin="8" />
      </TabItem>
      <TabItem Header="Live Context">
        <views:LiveContextTab x:Name="TabLive" Margin="8" />
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
